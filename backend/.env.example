# ==============================================================================
# THESISFLOW BACKEND ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================

# 1. DATABASE CONFIGURATION (PostgreSQL - Neon.tech / Supabase / Railway)
DATABASE_URL="postgresql://user:password@ep-host.region.aws.neon.tech/neondb?sslmode=require"

# 2. AUTHENTICATION & SECURITY (JWT)
JWT_SECRET="your_secure_random_jwt_secret_here"
JWT_EXPIRES_IN="7d"

# 3. SERVER CONFIGURATION
PORT=3000
CLIENT_URL="http://localhost:5173"

# 4. CLOUDINARY FILE STORAGE (25 GB Free Document Hosting for PDFs & DOCX)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
